		{
			"name": "pick",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"let response = pm.response.json();",
							"",
							"if (pm.response.code === 200) {",
							"",
							"    // newly created shipment",
							"    if (response.shipmentIds &&",
							"        response.shipmentIds.length > 0) {",
							"",
							"        pm.environment.set(",
							"            \"shipmentId\",",
							"            response.shipmentIds[0]",
							"        );",
							"",
							"        console.log(",
							"            \"Shipment created:\",",
							"            response.shipmentIds[0]",
							"        );",
							"",
							"        pm.execution.setNextRequest(\"pack\");",
							"    }",
							"",
							"    // shipment already exists",
							"    else if (pm.environment.get(\"shipmentId\")) {",
							"",
							"        console.log(",
							"            \"Using existing shipment:\",",
							"            pm.environment.get(\"shipmentId\")",
							"        );",
							"",
							"        pm.execution.setNextRequest(\"pack\");",
							"    }",
							"",
							"    else {",
							"",
							"        console.log(\"No shipment found\");",
							"",
							"        pm.execution.setNextRequest(null);",
							"",
							"    }",
							"",
							"}",
							"else{",
							"",
							"    pm.execution.setNextRequest(null);",
							"",
							"}"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
